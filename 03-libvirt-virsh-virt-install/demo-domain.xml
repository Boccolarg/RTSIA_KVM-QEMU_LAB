<!--
  demo-domain.xml : a minimal libvirt domain definition for the lab.
  Equivalent to a 'virt-install' invocation with name=demo, memory=1024,
  vcpus=2, etc., but written out so you can read it.

  Usage:
    virsh define demo-domain.xml          # register the domain
    virsh start demo                       # boot it
    virsh shutdown demo                    # graceful poweroff
    virsh destroy demo                     # forceful (like pulling the plug)
    virsh undefine demo                    # forget the definition

  Edit /var/lib/libvirt/images/demo.qcow2 path below if you put the image elsewhere.
-->
<domain type='kvm'>
  <name>demo</name>
  <memory unit='MiB'>1024</memory>
  <currentMemory unit='MiB'>1024</currentMemory>

  <vcpu placement='static'>2</vcpu>

  <!--
    cputune lets you pin vCPU threads to specific host CPUs (Exp 05).
    Uncomment and edit to use; cpuset='1' pins vCPU 0 to host CPU 1.
  -->
  <!--
  <cputune>
    <vcpupin vcpu='0' cpuset='1'/>
    <vcpupin vcpu='1' cpuset='3'/>
    <emulatorpin cpuset='0,2'/>
  </cputune>
  -->

  <os>
    <type arch='x86_64' machine='q35'>hvm</type>
    <boot dev='hd'/>
  </os>

  <features>
    <acpi/>
    <apic/>
  </features>

  <!-- 'host-passthrough' = expose the host CPU model 1:1 to the guest. -->
  <cpu mode='host-passthrough' check='none' migratable='off'/>

  <clock offset='utc'>
    <timer name='rtc' tickpolicy='catchup'/>
    <timer name='pit' tickpolicy='delay'/>
    <timer name='hpet' present='no'/>
  </clock>

  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>

  <devices>
    <emulator>/usr/bin/qemu-system-x86_64</emulator>

    <!-- The guest disk. EDIT THE PATH if your image is elsewhere. -->
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2' cache='none' io='native' discard='unmap'/>
      <source file='/var/lib/libvirt/images/demo.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>

    <!-- Paravirtualized NIC on the default libvirt NAT network 'default'. -->
    <interface type='network'>
      <source network='default'/>
      <model type='virtio'/>
    </interface>

    <!-- Serial console + graphical SPICE console. -->
    <serial type='pty'>
      <target type='isa-serial' port='0'/>
    </serial>
    <console type='pty'>
      <target type='serial' port='0'/>
    </console>

    <graphics type='spice' autoport='yes'>
      <listen type='address' address='127.0.0.1'/>
    </graphics>

    <video>
      <model type='qxl'/>
    </video>

    <!-- Misc. paravirtualized devices. -->
    <memballoon model='virtio'/>
    <rng model='virtio'>
      <backend model='random'>/dev/urandom</backend>
    </rng>
  </devices>
</domain>
